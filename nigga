function SeraphUI:AddNavTab(name)
    local tabData = {
        Name     = name,
        Button   = nil,
        TopTabs  = {},
        ActiveTopTab = nil,
    }

    local btn = Create("TextButton", {
        Name            = name,
        Text            = name:lower(),
        Font            = Enum.Font.Gotham,
        TextSize        = 12,
        TextColor3      = Theme.TabInactive,
        BackgroundTransparency = 1,
        Size            = UDim2.new(0, 120, 1, 0),
        AutoButtonColor = false,
        Parent          = self.NavLayout,
    })

    -- Active underline indicator
    local indicator = Create("Frame", {
        Name            = "Indicator",
        Size            = UDim2.new(0.6, 0, 0, 2),
        Position        = UDim2.new(0.2, 0, 1, -2),
        BackgroundColor3 = Theme.Accent,
        BorderSizePixel = 0,
        Visible         = false,
        Parent          = btn,
    })
    MakeCorner(2).Parent = indicator

    tabData.Button    = btn
    tabData.Indicator = indicator

    btn.MouseButton1Click:Connect(function()
        self:SelectNavTab(name)
    end)

    btn.MouseEnter:Connect(function()
        if self.ActiveNavTab ~= name then
            Tween(btn, FastTween, { TextColor3 = Theme.TextDim })
        end
    end)
    btn.MouseLeave:Connect(function()
        if self.ActiveNavTab ~= name then
            Tween(btn, FastTween, { TextColor3 = Theme.TabInactive })
        end
    end)

    table.insert(self.NavTabs, tabData)
    self.Tabs[name] = tabData

    if #self.NavTabs == 1 then
        task.defer(function() self:SelectNavTab(name) end)
    end

    return tabData
end

function SeraphUI:SelectNavTab(name)
    self.ActiveNavTab = name
    for _, t in pairs(self.NavTabs) do
        local isActive = (t.Name == name)
        Tween(t.Button, FastTween, {
            TextColor3 = isActive and Theme.TabActive or Theme.TabInactive
        })
        t.Indicator.Visible = isActive

        -- Show/hide the top tab rows and columns belonging to this nav tab
        if t.TopTabs then
            for _, tt in pairs(t.TopTabs) do
                tt.Button.Visible = isActive
            end
        end
    end

    -- Auto-select first top tab of this nav tab
    local navTab = self.Tabs[name]
    if navTab and #navTab.TopTabs > 0 then
        local firstTop = navTab.TopTabs[1].Name
        self:SelectTopTab(name, firstTop)
    else
        -- Clear columns
        for _, v in pairs(self.LeftCol:GetChildren()) do
            if not v:IsA("UIListLayout") and not v:IsA("UIPadding") then
                v.Visible = false
            end
        end
        for _, v in pairs(self.RightCol:GetChildren()) do
            if not v:IsA("UIListLayout") and not v:IsA("UIPadding") then
                v.Visible = false
            end
        end
    end
end

-- ═══════════════════════════════════════════════════════════════════════════════
--  TOP TAB  (aimbot | scanning | anti-aim  /  movement | misc | backtrack)
-- ═══════════════════════════════════════════════════════════════════════════════
function SeraphUI:AddTopTab(navTabName, name, side)
    side = side or "left"
    local navTab = self.Tabs[navTabName]
    if not navTab then return end

    local container = (side == "left") and self.LeftTabContainer or self.RightTabContainer

    local topTabData = {
        Name       = name,
        Side       = side,
        Button     = nil,
        LeftItems  = {},   -- elements in left column
        RightItems = {},   -- elements in right column
    }

    local btn = Create("TextButton", {
        Name            = name,
        Text            = name:lower(),
        Font            = Enum.Font.Gotham,
        TextSize        = 12,
        TextColor3      = Theme.TabInactive,
        BackgroundTransparency = 1,
        Size            = UDim2.new(0, 0, 1, 0),
        AutomaticSize   = Enum.AutomaticSize.X,
        AutoButtonColor = false,
        Visible         = false,
        Parent          = container,
    })
    MakePadding(0, 0, 10, 10).Parent = btn

    -- Underline
    local uline = Create("Frame", {
        Name            = "Underline",
        Size            = UDim2.new(1, -20, 0, 1),
        Position        = UDim2.new(0, 10, 1, -1),
        BackgroundColor3 = Theme.Accent,
        BorderSizePixel = 0,
        Visible         = false,
        Parent          = btn,
    })

    topTabData.Button    = btn
    topTabData.Underline = uline

    btn.MouseButton1Click:Connect(function()
        self:SelectTopTab(navTabName, name)
    end)
    btn.MouseEnter:Connect(function()
        if navTab.ActiveTopTab ~= name then
            Tween(btn, FastTween, { TextColor3 = Theme.TextDim })
        end
    end)
    btn.MouseLeave:Connect(function()
        if navTab.ActiveTopTab ~= name then
            Tween(btn, FastTween, { TextColor3 = Theme.TabInactive })
        end
    end)

    table.insert(navTab.TopTabs, topTabData)
    topTabData.NavTabName = navTabName

    return topTabData
end

function SeraphUI:SelectTopTab(navTabName, topTabName)
    local navTab = self.Tabs[navTabName]
    if not navTab then return end

    navTab.ActiveTopTab = topTabName

    -- Update button styles
    for _, tt in pairs(navTab.TopTabs) do
        local isActive = (tt.Name == topTabName)
        Tween(tt.Button, FastTween, {
            TextColor3 = isActive and Theme.TabActive or Theme.TabInactive
        })
        if tt.Underline then
            tt.Underline.Visible = isActive
        end
    end

    -- Show/hide the content items
    for _, tt in pairs(navTab.TopTabs) do
        local isActive = (tt.Name == topTabName)
        for _, item in pairs(tt.LeftItems) do
            if item and item.Parent then
                item.Visible = isActive
            end
        end
        for _, item in pairs(tt.RightItems) do
            if item and item.Parent then
                item.Visible = isActive
            end
        end
    end
end

