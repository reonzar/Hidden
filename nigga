function SeraphUI:AddToggle(navTabName, topTabName, config)
    config = config or {}
    local label   = config.Label    or "Toggle"
    local default = config.Default  ~= false
    local column  = config.Column   or "left"
    local callback = config.Callback or function() end
    local hasHelp = config.Help     ~= false

    local topTab = self:GetTopTab(navTabName, topTabName)
    if not topTab then return end

    local col = (column == "left") and self.LeftCol or self.RightCol
    local value = default

    local row = Create("Frame", {
        Name            = label .. "Row",
        Size            = UDim2.new(1, 0, 0, 26),
        BackgroundTransparency = 1,
        Visible         = false,
        Parent          = col,
    })

    -- Label
    Create("TextLabel", {
        Name            = "Label",
        Text            = label:lower(),
        Font            = Enum.Font.Gotham,
        TextSize        = 12,
        TextColor3      = Theme.Text,
        TextXAlignment  = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        Size            = UDim2.new(1, -30, 1, 0),
        Parent          = row,
    })

    -- Help "?"
    if hasHelp then
        Create("TextLabel", {
            Name            = "Help",
            Text            = " ?",
            Font            = Enum.Font.Gotham,
            TextSize        = 9,
            TextColor3      = Theme.TextDim,
            TextXAlignment  = Enum.TextXAlignment.Left,
            BackgroundTransparency = 1,
            Size            = UDim2.new(0, 16, 1, 0),
            Position        = UDim2.new(0, #label * 7, 0, 0),
            Parent          = row,
        })
    end

    -- Checkbox
    local checkbox = Create("TextButton", {
        Name            = "Checkbox",
        Text            = "",
        BackgroundColor3 = value and Theme.ToggleOn or Theme.ToggleOff,
        Size            = UDim2.new(0, 14, 0, 14),
        Position        = UDim2.new(1, -14, 0.5, -7),
        AutoButtonColor = false,
        BorderSizePixel = 0,
        Parent          = row,
    })
    MakeCorner(2).Parent = checkbox
    MakeStroke(value and Theme.Accent or Theme.Border, 1).Parent = checkbox

    local function updateVisual()
        Tween(checkbox, FastTween, {
            BackgroundColor3 = value and Theme.ToggleOn or Theme.ToggleOff
        })
        local stroke = checkbox:FindFirstChildOfClass("UIStroke")
        if stroke then
            Tween(stroke, FastTween, {
                Color = value and Theme.Accent or Theme.Border
            })
        end
    end

    checkbox.MouseButton1Click:Connect(function()
        value = not value
        updateVisual()
        callback(value)
    end)

    checkbox.MouseEnter:Connect(function()
        Tween(checkbox, FastTween, { BackgroundColor3 = value and Theme.AccentHover or Color3.fromRGB(45, 45, 45) })
    end)
    checkbox.MouseLeave:Connect(function()
        updateVisual()
    end)

    local ctrl = {
        Row      = row,
        Checkbox = checkbox,
        Value    = function() return value end,
        Set      = function(_, v)
            value = v
            updateVisual()
            callback(value)
        end,
    }

    if column == "left" then
        table.insert(topTab.LeftItems, row)
    else
        table.insert(topTab.RightItems, row)
    end

    return ctrl
end

-- ─────────────────────────────────────────────────────────────────────────────
--  SLIDER  (with optional gear icon)
-- ─────────────────────────────────────────────────────────────────────────────
function SeraphUI:AddSlider(navTabName, topTabName, config)
    config = config or {}
    local label    = config.Label    or "Slider"
    local min      = config.Min      or 0
    local max      = config.Max      or 100
    local default  = config.Default  or min
    local column   = config.Column   or "left"
    local callback = config.Callback or function() end
    local suffix   = config.Suffix   or ""
    local hasGear  = config.Gear     ~= false
    local hasHelp  = config.Help     ~= false

    local topTab = self:GetTopTab(navTabName, topTabName)
    if not topTab then return end

    local col = (column == "left") and self.LeftCol or self.RightCol
    local value = math.clamp(default, min, max)

    local container = Create("Frame", {
        Name            = label .. "Container",
        Size            = UDim2.new(1, 0, 0, 38),
        BackgroundTransparency = 1,
        Visible         = false,
        Parent          = col,
    })

    -- Top row: label + gear + checkbox
    local topRow = Create("Frame", {
        Size            = UDim2.new(1, 0, 0, 22),
        BackgroundTransparency = 1,
        Parent          = container,
    })

    Create("TextLabel", {
        Text            = label:lower(),
        Font            = Enum.Font.Gotham,
        TextSize        = 12,
        TextColor3      = Theme.Text,
        TextXAlignment  = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        Size            = UDim2.new(1, -50, 1, 0),
        Parent          = topRow,
    })

    if hasHelp then
        Create("TextLabel", {
            Text            = " ?",
            Font            = Enum.Font.Gotham,
            TextSize        = 9,
            TextColor3      = Theme.TextDim,
            BackgroundTransparency = 1,
            Size            = UDim2.new(0, 16, 1, 0),
            Position        = UDim2.new(0, #label * 7, 0, 0),
            Parent          = topRow,
        })
    end

    -- Gear icon (◇)
    if hasGear then
        Create("TextLabel", {
            Text            = "◇",
            Font            = Enum.Font.Gotham,
            TextSize        = 10,
            TextColor3      = Theme.TextDim,
            BackgroundTransparency = 1,
            Size            = UDim2.new(0, 16, 1, 0),
            Position        = UDim2.new(1, -30, 0, 0),
            Parent          = topRow,
        })
    end

    -- Enabled checkbox on right
    local sliderEnabled = true
    local enableBox = Create("TextButton", {
        Text            = "",
        BackgroundColor3 = Theme.ToggleOn,
        Size            = UDim2.new(0, 14, 0, 14),
        Position        = UDim2.new(1, -14, 0.5, -7),
        AutoButtonColor = false,
        BorderSizePixel = 0,
        Parent          = topRow,
    })
    MakeCorner(2).Parent = enableBox
    MakeStroke(Theme.Accent, 1).Parent = enableBox

    enableBox.MouseButton1Click:Connect(function()
        sliderEnabled = not sliderEnabled
        Tween(enableBox, FastTween, {
            BackgroundColor3 = sliderEnabled and Theme.ToggleOn or Theme.ToggleOff
        })
    end)

    -- Slider bar
    local barBg = Create("Frame", {
        Size            = UDim2.new(1, 0, 0, 6),
        Position        = UDim2.new(0, 0, 0, 28),
        BackgroundColor3 = Theme.SliderBg,
        BorderSizePixel = 0,
        Parent          = container,
    })
    MakeCorner(3).Parent = barBg

    local fill = Create("Frame", {
        Size            = UDim2.new((value - min) / (max - min), 0, 1, 0),
        BackgroundColor3 = Theme.SliderFill,
        BorderSizePixel = 0,
        Parent          = barBg,
    })
    MakeCorner(3).Parent = fill

    -- Value label
    local valLabel = Create("TextLabel", {
        Text            = tostring(value) .. suffix,
        Font            = Enum.Font.Gotham,
        TextSize        = 10,
        TextColor3      = Theme.TextDim,
        TextXAlignment  = Enum.TextXAlignment.Right,
        BackgroundTransparency = 1,
        Size            = UDim2.new(1, 0, 0, 14),
        Position        = UDim2.new(0, 0, 0, 14),
        Parent          = container,
    })

    -- Drag logic
    local dragging = false

    local function updateSlider(inputX)
        local barAbs = barBg.AbsolutePosition.X
        local barW   = barBg.AbsoluteSize.X
        local rel    = math.clamp((inputX - barAbs) / barW, 0, 1)
        value = math.floor(min + rel * (max - min) + 0.5)
        fill.Size = UDim2.new(rel, 0, 1, 0)
        valLabel.Text = tostring(value) .. suffix
        callback(value)
    end

    barBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            updateSlider(input.Position.X)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            updateSlider(input.Position.X)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    local ctrl = {
        Container = container,
        Value     = function() return value end,
        Set       = function(_, v)
            value = math.clamp(v, min, max)
            local rel = (value - min) / (max - min)
            fill.Size = UDim2.new(rel, 0, 1, 0)
            valLabel.Text = tostring(value) .. suffix
            callback(value)
        end,
    }

    if column == "left" then
        table.insert(topTab.LeftItems, container)
    else
        table.insert(topTab.RightItems, container)
    end

    return ctrl
end

-- ─────────────────────────────────────────────────────────────────────────────
--  DROPDOWN
-- ─────────────────────────────────────────────────────────────────────────────
function SeraphUI:AddDropdown(navTabName, topTabName, config)
    config = config or {}
    local label    = config.Label    or "Dropdown"
    local options  = config.Options  or {}
    local default  = config.Default  or options[1] or "none"
    local column   = config.Column   or "left"
    local callback = config.Callback or function() end

    local topTab = self:GetTopTab(navTabName, topTabName)
    if not topTab then return end

    local col = (column == "left") and self.LeftCol or self.RightCol
    local selected = default
    local open = false

    local container = Create("Frame", {
        Name            = label .. "Dropdown",
        Size            = UDim2.new(1, 0, 0, 26),
        BackgroundTransparency = 1,
        ClipsDescendants = false,
        Visible         = false,
        Parent          = col,
    })

    -- Label
    Create("TextLabel", {
        Text            = label:lower(),
        Font            = Enum.Font.Gotham,
        TextSize        = 12,
        TextColor3      = Theme.Text,
        TextXAlignment  = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        Size            = UDim2.new(0.4, 0, 1, 0),
        Parent          = container,
    })

    -- Dropdown button
    local dropBtn = Create("TextButton", {
        Text            = selected,
        Font            = Enum.Font.Gotham,
        TextSize        = 11,
        TextColor3      = Theme.TextDim,
        BackgroundColor3 = Theme.DropdownBg,
        BorderSizePixel = 0,
        Size            = UDim2.new(0.55, 0, 1, 0),
        Position        = UDim2.new(0.44, 0, 0, 0),
        AutoButtonColor = false,
        Parent          = container,
    })
    MakeCorner(3).Parent = dropBtn
    MakeStroke(Theme.Border, 1).Parent = dropBtn
    MakePadding(0, 0, 6, 6).Parent = dropBtn

    -- Arrow "▾"
    Create("TextLabel", {
        Text            = "▾",
        Font            = Enum.Font.Gotham,
        TextSize        = 10,
        TextColor3      = Theme.TextDim,
        BackgroundTransparency = 1,
        Size            = UDim2.new(0, 16, 1, 0),
        Position        = UDim2.new(1, -18, 0, 0),
        Parent          = dropBtn,
    })

    -- Dropdown list
    local listFrame = Create("Frame", {
        Name            = "List",
        BackgroundColor3 = Theme.DropdownBg,
        BorderSizePixel = 0,
        Size            = UDim2.new(0.55, 0, 0, 0),
        Position        = UDim2.new(0.44, 0, 1, 2),
        ClipsDescendants = true,
        ZIndex          = 10,
        Visible         = false,
        Parent          = container,
    })
    MakeCorner(3).Parent = listFrame
    MakeStroke(Theme.Border, 1).Parent = listFrame
    MakeListLayout(Enum.FillDirection.Vertical, 0).Parent = listFrame

    local function closeDropdown()
        open = false
        Tween(listFrame, FastTween, { Size = UDim2.new(0.55, 0, 0, 0) })
        task.delay(0.15, function() listFrame.Visible = false end)
    end

    local function buildList()
        for _, v in pairs(listFrame:GetChildren()) do
            if v:IsA("TextButton") then v:Destroy() end
        end
        for _, opt in pairs(options) do
            local optBtn = Create("TextButton", {
                Text            = opt,
                Font            = Enum.Font.Gotham,
                TextSize        = 11,
                TextColor3      = opt == selected and Theme.TextActive or Theme.TextDim,
                BackgroundTransparency = opt == selected and 0.7 or 1,
                BackgroundColor3 = Theme.Accent,
                BorderSizePixel = 0,
                Size            = UDim2.new(1, 0, 0, 22),
                AutoButtonColor = false,
                ZIndex          = 11,
                Parent          = listFrame,
            })
            MakePadding(0, 0, 6, 6).Parent = optBtn

            optBtn.MouseEnter:Connect(function()
                Tween(optBtn, FastTween, { BackgroundTransparency = 0.6, TextColor3 = Theme.TextActive })
            end)
            optBtn.MouseLeave:Connect(function()
                Tween(optBtn, FastTween, {
                    BackgroundTransparency = opt == selected and 0.7 or 1,
                    TextColor3 = opt == selected and Theme.TextActive or Theme.TextDim
                })
            end)

            optBtn.MouseButton1Click:Connect(function()
                selected = opt
                dropBtn.Text = selected
                buildList()
                closeDropdown()
                callback(selected)
            end)
        end

        local totalH = #options * 22
        if open then
            Tween(listFrame, FastTween, { Size = UDim2.new(0.55, 0, 0, totalH) })
        end
    end

    dropBtn.MouseButton1Click:Connect(function()
        open = not open
        if open then
            listFrame.Visible = true
            buildList()
        else
            closeDropdown()
        end
    end)

    local ctrl = {
        Container = container,
        Value     = function() return selected end,
        Set       = function(_, v)
            selected = v
            dropBtn.Text = v
            buildList()
            callback(v)
        end,
        SetOptions = function(_, opts)
            options = opts
            selected = opts[1] or "none"
            dropBtn.Text = selected
        end,
    }

    if column == "left" then
        table.insert(topTab.LeftItems, container)
    else
        table.insert(topTab.RightItems, container)
    end

    return ctrl
end

