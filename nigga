-- Helper: get the TopTabData object
function SeraphUI:GetTopTab(navTabName, topTabName)
    local navTab = self.Tabs[navTabName]
    if not navTab then return nil end
    for _, tt in pairs(navTab.TopTabs) do
        if tt.Name == topTabName then return tt end
    end
    return nil
end

