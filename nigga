-- UI Library Module
local UILibrary = {}
local players = game:GetService("Players")
local playerGui = players.LocalPlayer:WaitForChild("PlayerGui")

-- Create main screen GUI
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "SeraphUI"
screenGui.Parent = playerGui
screenGui.ResetOnSpawn = false
screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

-- Theme colors (based on the image)
local theme = {
    background = Color3.fromRGB(20, 20, 25),
    darker = Color3.fromRGB(15, 15, 20),
    text = Color3.fromRGB(255, 255, 255),
    grayText = Color3.fromRGB(180, 180, 180),
    accent = Color3.fromRGB(100, 200, 255),
    checkboxBg = Color3.fromRGB(40, 40, 50),
    toggleOn = Color3.fromRGB(100, 200, 255),
    toggleOff = Color3.fromRGB(60, 60, 70),
    border = Color3.fromRGB(30, 30, 40)
}

-- Main window creation function
function UILibrary:CreateWindow(title)
    -- Main frame
    local mainFrame = Instance.new("Frame")
    mainFrame.Name = "MainWindow"
    mainFrame.Size = UDim2.new(0, 800, 0, 600)
    mainFrame.Position = UDim2.new(0.5, -400, 0.5, -300)
    mainFrame.BackgroundColor3 = theme.background
    mainFrame.BorderSizePixel = 0
    mainFrame.Parent = screenGui
    
    -- Add shadow/drop shadow effect
    local shadow = Instance.new("Frame")
    shadow.Name = "Shadow"
    shadow.Size = UDim2.new(1, 10, 1, 10)
    shadow.Position = UDim2.new(0, -5, 0, -5)
    shadow.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    shadow.BackgroundTransparency = 0.5
    shadow.BorderSizePixel = 0
    shadow.ZIndex = -1
    shadow.Parent = mainFrame
    
    -- Top bar
    local topBar = Instance.new("Frame")
    topBar.Name = "TopBar"
    topBar.Size = UDim2.new(1, 0, 0, 30)
    topBar.BackgroundColor3 = theme.darker
    topBar.BorderSizePixel = 0
    topBar.Parent = mainFrame
    
    -- Title text
    local titleText = Instance.new("TextLabel")
    titleText.Name = "Title"
    titleText.Size = UDim2.new(1, -10, 1, 0)
    titleText.Position = UDim2.new(0, 10, 0, 0)
    titleText.BackgroundTransparency = 1
    titleText.Text = title .. " development | legitbot"
    titleText.TextColor3 = theme.text
    titleText.TextXAlignment = Enum.TextXAlignment.Left
    titleText.Font = Enum.Font.GothamBold
    titleText.TextSize = 16
    titleText.Parent = topBar
    
    -- Main content container
    local contentContainer = Instance.new("Frame")
    contentContainer.Name = "ContentContainer"
    contentContainer.Size = UDim2.new(1, 0, 1, -30)
    contentContainer.Position = UDim2.new(0, 0, 0, 30)
    contentContainer.BackgroundTransparency = 1
    contentContainer.Parent = mainFrame
    
    -- Left panel (navigation)
    local leftPanel = Instance.new("Frame")
    leftPanel.Name = "LeftPanel"
    leftPanel.Size = UDim2.new(0, 120, 1, 0)
    leftPanel.BackgroundColor3 = theme.darker
    leftPanel.BorderSizePixel = 0
    leftPanel.Parent = contentContainer
    
    -- Navigation buttons
    local navButtons = {"aimbot", "scanning", "anti-aim", "movement", "misc", "backtrack"}
    local buttonSpacing = 35
    local startY = 10
    
    for i, btnName in ipairs(navButtons) do
        local button = Instance.new("TextButton")
        button.Name = btnName .. "Button"
        button.Size = UDim2.new(1, -20, 0, 25)
        button.Position = UDim2.new(0, 10, 0, startY + (i-1) * buttonSpacing)
        button.BackgroundColor3 = theme.darker
        button.BackgroundTransparency = 1
        button.Text = btnName
        button.TextColor3 = theme.grayText
        button.TextXAlignment = Enum.TextXAlignment.Left
        button.Font = Enum.Font.Gotham
        button.TextSize = 14
        button.Parent = leftPanel
        
        -- Hover effect
        button.MouseEnter:Connect(function()
            if button.BackgroundTransparency == 1 then
                button.BackgroundTransparency = 0.8
                button.BackgroundColor3 = theme.accent
            end
        end)
        
        button.MouseLeave:Connect(function()
            if button.BackgroundTransparency == 0.8 then
                button.BackgroundTransparency = 1
            end
        end)
    end
    
    -- Right panel (main content)
    local rightPanel = Instance.new("Frame")
    rightPanel.Name = "RightPanel"
    rightPanel.Size = UDim2.new(1, -120, 1, 0)
    rightPanel.Position = UDim2.new(0, 120, 0, 0)
    rightPanel.BackgroundColor3 = theme.background
    rightPanel.BorderSizePixel = 0
    rightPanel.Parent = contentContainer
    
    -- Add tab content
    local function createToggle(parent, name, posX, posY)
        local toggleContainer = Instance.new("Frame")
        toggleContainer.Name = name .. "Container"
        toggleContainer.Size = UDim2.new(0, 120, 0, 30)
        toggleContainer.Position = UDim2.new(0, posX, 0, posY)
        toggleContainer.BackgroundTransparency = 1
        toggleContainer.Parent = parent
        
        local toggleBg = Instance.new("Frame")
        toggleBg.Name = "ToggleBg"
        toggleBg.Size = UDim2.new(0, 20, 0, 20)
        toggleBg.Position = UDim2.new(0, 0, 0.5, -10)
        toggleBg.BackgroundColor3 = theme.toggleOff
        toggleBg.BorderSizePixel = 0
        toggleBg.Parent = toggleContainer
        
        local toggleIndicator = Instance.new("Frame")
        toggleIndicator.Name = "ToggleIndicator"
        toggleIndicator.Size = UDim2.new(0, 14, 0, 14)
        toggleIndicator.Position = UDim2.new(0, 3, 0.5, -7)
        toggleIndicator.BackgroundColor3 = theme.grayText
        toggleIndicator.BorderSizePixel = 0
        toggleIndicator.Parent = toggleBg
        
        local toggleText = Instance.new("TextLabel")
        toggleText.Name = "ToggleText"
        toggleText.Size = UDim2.new(1, -25, 1, 0)
        toggleText.Position = UDim2.new(0, 25, 0, 0)
        toggleText.BackgroundTransparency = 1
        toggleText.Text = name
        toggleText.TextColor3 = theme.text
        toggleText.TextXAlignment = Enum.TextXAlignment.Left
        toggleText.Font = Enum.Font.Gotham
        toggleText.TextSize = 14
        toggleText.Parent = toggleContainer
        
        local toggled = false
        toggleBg.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                toggled = not toggled
                if toggled then
                    toggleBg.BackgroundColor3 = theme.toggleOn
                    toggleIndicator.BackgroundColor3 = theme.text
                else
                    toggleBg.BackgroundColor3 = theme.toggleOff
                    toggleIndicator.BackgroundColor3 = theme.grayText
                end
            end
        end)
    end
    
    -- Add aimbot section with toggles
    local aimbotSection = Instance.new("Frame")
    aimbotSection.Name = "AimbotSection"
    aimbotSection.Size = UDim2.new(1, -30, 1, -20)
    aimbotSection.Position = UDim2.new(0, 20, 0, 20)
    aimbotSection.BackgroundTransparency = 1
    aimbotSection.Parent = rightPanel
    
    createToggle(aimbotSection, "enabled", 0, 0)
    createToggle(aimbotSection, "auto pathfind", 150, 0)
    
    -- Add scanner icon (visual representation)
    local scannerFrame = Instance.new("Frame")
    scannerFrame.Name = "ScannerFrame"
    scannerFrame.Size = UDim2.new(0, 300, 0, 60)
    scannerFrame.Position = UDim2.new(0, 0, 0, 40)
    scannerFrame.BackgroundColor3 = theme.darker
    scannerFrame.BorderSizePixel = 0
    scannerFrame.Parent = aimbotSection
    
    local scannerText = Instance.new("TextLabel")
    scannerText.Name = "ScannerText"
    scannerText.Size = UDim2.new(1, -10, 1, 0)
    scannerText.Position = UDim2.new(0, 10, 0, 0)
    scannerText.BackgroundTransparency = 1
    scannerText.Text = "scanning"
    scannerText.TextColor3 = theme.text
    scannerText.TextXAlignment = Enum.TextXAlignment.Left
    scannerText.Font = Enum.Font.GothamBold
    scannerText.TextSize = 16
    scannerText.Parent = scannerFrame
    
    -- Movement settings
    createToggle(aimbotSection, "walkspeed", 0, 110)
    createToggle(aimbotSection, "jump power", 150, 110)
    createToggle(aimbotSection, "sound override", 0, 150)
    createToggle(aimbotSection, "multithreading", 0, 190)
    createToggle(aimbotSection, "resolver", 0, 230)
    createToggle(aimbotSection, "damage prediction", 0, 270)
    createToggle(aimbotSection, "filtering", 0, 310)
    
    -- "none" text at bottom
    local noneText = Instance.new("TextLabel")
    noneText.Name = "NoneText"
    noneText.Size = UDim2.new(1, -20, 0, 30)
    noneText.Position = UDim2.new(0, 10, 1, -40)
    noneText.BackgroundTransparency = 1
    noneText.Text = "none"
    noneText.TextColor3 = theme.grayText
    noneText.TextXAlignment = Enum.TextXAlignment.Left
    noneText.Font = Enum.Font.Gotham
    noneText.TextSize = 14
    noneText.Parent = aimbotSection
    
    -- Make window draggable
    local dragging = false
    local dragInput
    local dragStart
    local startPos
    
    topBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = mainFrame.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    
    topBar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            dragInput = input
        end
    end)
    
    game:GetService("UserInputService").InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            mainFrame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
    
    return mainFrame
end

return UILibrary
